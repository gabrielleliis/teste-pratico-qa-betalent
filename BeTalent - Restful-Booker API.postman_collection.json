    {
      "name": "Booking",
      "item": [
        {
          "name": "Create Booking",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// 1. Valida o Status Code\r",
                  "pm.test(\"Status code is 200 OK\", function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "// 2. Teste de Performance: Garante que a API responde em menos de 1 segundo (1000ms)\r",
                  "pm.test(\"Tempo de resposta menor que 1000ms\", function () {\r",
                  "    pm.expect(pm.response.responseTime).to.be.below(1000);\r",
                  "});\r",
                  "\r",
                  "// 3. Validação de Contrato (Dados)\r",
                  "pm.test(\"Garante que a reserva foi criada com os dados corretos\", function () {\r",
                  "    var jsonData = pm.response.json();\r",
                  "    \r",
                  "    // Verifica se gerou o ID\r",
                  "    pm.expect(jsonData).to.have.property(\"bookingid\");\r",
                  "    pm.expect(jsonData.bookingid).to.be.a(\"number\");\r",
                  "    \r",
                  "    // Verifica se salvou o nome exato e o tipo do dado (boolean)\r",
                  "    pm.expect(jsonData.booking.firstname).to.eql(\"Jim\");\r",
                  "    pm.expect(jsonData.booking.depositpaid).to.be.a(\"boolean\");\r",
                  "});\r",
                  "\r",
                  "// 4. Salva o ID na variável para os próximos testes (que você já tinha feito)\r",
                  "var jsonData = pm.response.json();\r",
                  "if(jsonData.bookingid) {\r",
                  "    pm.collectionVariables.set(\"bookingid\", jsonData.bookingid);\r",
                  "}"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              },
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\r\n    \"firstname\" : \"Jim\",\r\n    \"lastname\" : \"Brown\",\r\n    \"totalprice\" : 111,\r\n    \"depositpaid\" : true,\r\n    \"bookingdates\" : {\r\n        \"checkin\" : \"2024-01-01\",\r\n        \"checkout\" : \"2024-01-10\"\r\n    },\r\n    \"additionalneeds\" : \"Breakfast\"\r\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/booking",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "booking"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Get Booking",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// 1. Valida se a busca deu certo\r",
                  "pm.test(\"Status code is 200 OK\", function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "// 2. Teste de Performance (GETs devem ser rápidos)\r",
                  "pm.test(\"Tempo de resposta menor que 800ms\", function () {\r",
                  "    pm.expect(pm.response.responseTime).to.be.below(800);\r",
                  "});\r",
                  "\r",
                  "// 3. Validação dos Dados da Reserva\r",
                  "pm.test(\"Garante que os dados do hóspede estão corretos\", function () {\r",
                  "    var jsonData = pm.response.json();\r",
                  "    \r",
                  "    pm.expect(jsonData).to.have.property(\"firstname\");\r",
                  "    pm.expect(jsonData).to.have.property(\"lastname\");\r",
                  "    pm.expect(jsonData.totalprice).to.be.a(\"number\");\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
